{
  "displayName": "CA-COV006-Global-BlockUnknownPlatforms",
  "state": "enabledForReportingButNotEnforced",
  "conditions": {
    "applications": {
      "includeApplications": [
        "All"
      ]
    },
    "clientAppTypes": [
      "all"
    ],
    "platforms": {
      "excludePlatforms": [
        "android",
        "iOS",
        "windows",
        "windowsPhone",
        "macOS",
        "linux"
      ],
      "includePlatforms": [
        "all"
      ]
    },
    "users": {
      "excludeGroups": [
        "REPLACE_WITH_EMERGENCY_ACCESS_GROUP_OBJECT_ID",
        "REPLACE_WITH_WORKLOAD_IDENTITIES_GROUP_OBJECT_ID",
        "REPLACE_WITH_SERVICE_ACCOUNTS_GROUP_OBJECT_ID"
      ],
      "includeUsers": [
        "All"
      ]
    }
  },
  "grantControls": {
    "builtInControls": [
      "block"
    ],
    "operator": "OR"
  }
}
