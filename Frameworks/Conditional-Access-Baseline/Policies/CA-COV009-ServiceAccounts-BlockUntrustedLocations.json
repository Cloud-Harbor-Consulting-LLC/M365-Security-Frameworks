{
  "displayName": "CA-COV009-ServiceAccounts-BlockUntrustedLocations",
  "state": "enabledForReportingButNotEnforced",
  "conditions": {
    "applications": {
      "includeApplications": [
        "All"
      ]
    },
    "clientAppTypes": [
      "all"
    ],
    "locations": {
      "excludeLocations": [
        "REPLACE_WITH_TRUSTED_COUNTRIES_LOCATION_ID"
      ],
      "includeLocations": [
        "All"
      ]
    },
    "users": {
      "excludeGroups": [
        "REPLACE_WITH_EMERGENCY_ACCESS_GROUP_OBJECT_ID",
        "REPLACE_WITH_WORKLOAD_IDENTITIES_GROUP_OBJECT_ID"
      ],
      "includeGroups": [
        "REPLACE_WITH_SERVICE_ACCOUNTS_GROUP_OBJECT_ID"
      ]
    }
  },
  "grantControls": {
    "builtInControls": [
      "block"
    ],
    "operator": "OR"
  }
}
