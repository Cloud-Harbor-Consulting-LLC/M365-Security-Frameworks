{
  "displayName": "CA-COV008-Internal-RequireCompliantDeviceOnDesktops",
  "state": "enabledForReportingButNotEnforced",
  "conditions": {
    "applications": {
      "includeApplications": [
        "All"
      ]
    },
    "clientAppTypes": [
      "browser",
      "mobileAppsAndDesktopClients"
    ],
    "platforms": {
      "includePlatforms": [
        "windows",
        "macOS",
        "linux"
      ]
    },
    "users": {
      "excludeGroups": [
        "REPLACE_WITH_EMERGENCY_ACCESS_GROUP_OBJECT_ID",
        "REPLACE_WITH_WORKLOAD_IDENTITIES_GROUP_OBJECT_ID",
        "REPLACE_WITH_SERVICE_ACCOUNTS_GROUP_OBJECT_ID"
      ],
      "includeGroups": [
        "REPLACE_WITH_INTERNAL_USERS_GROUP_OBJECT_ID"
      ]
    }
  },
  "grantControls": {
    "builtInControls": [
      "compliantDevice",
      "domainJoinedDevice"
    ],
    "operator": "OR"
  }
}
